# ================== ENVIRONMENT ==================
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ================== AI PROVIDERS ==================
LLM_PROVIDER=auto

# Claude (Recommended - Best Quality)
ANTHROPIC_API_KEY=

# Gemini (Good free tier)
GEMINI_API_KEY=

# Groq (Very Fast)
GROQ_API_KEY=

# OpenAI / ChatGPT
OPENAI_API_KEY=

# Perplexity (Strong Research)
PERPLEXITY_API_KEY=

# Default Models
DEFAULT_CLAUDE_MODEL=claude-3-5-sonnet-20241022
DEFAULT_GEMINI_MODEL=gemini-2.0-flash
DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile
DEFAULT_OPENAI_MODEL=gpt-4o
DEFAULT_PERPLEXITY_MODEL=sonar-pro

# ================== DATA TOOLS ==================
SERPER_API_KEY=
FIRECRAWL_API_KEY=
PAGESPEED_API_KEY=

# ================== DATAFORSEO (Optional but Recommended) ==================
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ================== SUPABASE ==================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# HS256 secret used to VERIFY user JWTs (Supabase Dashboard > Settings > API >
# JWT Secret). If set, tokens are verified locally; if blank the backend falls
# back to validating each token against Supabase's /auth/v1/user endpoint.
SUPABASE_JWT_SECRET=

# ================== SECURITY ==================
# The app REFUSES TO START with the default/empty key (unless ENVIRONMENT=dev
# and ALLOW_DEFAULT_KEY=1). Generate a strong value, e.g. `openssl rand -hex 32`.
ORCHESTRATOR_API_KEY=
# Comma-separated allowlist of browser origins for CORS in production, e.g.
# https://app.omnirank.ai,https://omnirank.ai . '*' (dev default) disables
# credentialed CORS.
CORS_ORIGINS=*
# Local-only escape hatch to boot with the default key (never set in prod).
ALLOW_DEFAULT_KEY=

# ================== FRONTEND ==================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_NAME=OMNI-RANK
# NOTE: do NOT set NEXT_PUBLIC_API_KEY. The browser now authenticates as the
# logged-in user via their Supabase JWT; shipping the backend key to the
# browser would hand every visitor full backend access.

# ================== BILLING (Razorpay) ==================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=