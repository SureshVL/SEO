# ================== ENVIRONMENT ==================
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ================== AI PROVIDERS ==================
LLM_PROVIDER=auto

# Claude (Recommended - Best Quality)
ANTHROPIC_API_KEY=

# Gemini (Good free tier)
GEMINI_API_KEY=

# Groq (Very Fast)
GROQ_API_KEY=

# OpenAI / ChatGPT
OPENAI_API_KEY=

# Perplexity (Strong Research)
PERPLEXITY_API_KEY=

# Default Models
DEFAULT_CLAUDE_MODEL=claude-3-5-sonnet-20241022
DEFAULT_GEMINI_MODEL=gemini-2.0-flash
DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile
DEFAULT_OPENAI_MODEL=gpt-4o
DEFAULT_PERPLEXITY_MODEL=sonar-pro

# ================== DATA TOOLS ==================
SERPER_API_KEY=
FIRECRAWL_API_KEY=
PAGESPEED_API_KEY=

# ================== DATAFORSEO (Optional but Recommended) ==================
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ================== SUPABASE ==================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ================== SECURITY ==================
ORCHESTRATOR_API_KEY=dev-orchestrator-key-change-in-prod
JWT_SECRET=change-this-to-a-strong-secret

# ================== FRONTEND ==================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_NAME=OMNI-RANK

# ================== BILLING (Razorpay) ==================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=